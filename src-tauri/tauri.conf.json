{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeAuditt",
  "version": "0.1.0",
  "identifier": "com.vibeauditt.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeAuditt",
        "width": 1180,
        "height": 800,
        "minWidth": 940,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 VibeAuditt",
    "shortDescription": "Auditor de seguridad para SaaS hechos con IA",
    "longDescription": "VibeAuditt audita la seguridad de aplicaciones web y bases de datos: secretos expuestos, headers, CORS, Supabase RLS, CVEs, inyección (SQLi/SSTI/cmd) y más.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
